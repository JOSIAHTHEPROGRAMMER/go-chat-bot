# =============================================================================
# go-chat-bot — environment variable reference
# Copy this file to .env and fill in your values before running locally.
# Set these same variables in your Render dashboard for production.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers — Groq and Gemini rotate every 6 hours
# -----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Embeddings — Gemini text-embedding (gemini-embedding-001, 3072 dims)
# Uses the same GEMINI_API_KEY above — no extra key needed
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Reranking — Jina reranker v3
# Sign up free at https://jina.ai to get a key
# If not set, falls back to Qdrant cosine similarity ordering
# -----------------------------------------------------------------------------
JINA_API_KEY=your-jina-api-key

# -----------------------------------------------------------------------------
# Vector database — Qdrant Cloud
# Sign up free at https://cloud.qdrant.io
# -----------------------------------------------------------------------------
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_COLLECTION=portfolio
QDRANT_API_KEY=your-qdrant-api-key

# -----------------------------------------------------------------------------
# Conversation history — MongoDB Atlas
# Sign up free at https://cloud.mongodb.com
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DB=portfolio

# -----------------------------------------------------------------------------
# GitHub — used to fetch READMEs and language stats
# Token needs read:user and public_repo scopes
# -----------------------------------------------------------------------------
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-personal-access-token

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Frontend URL for CORS — set to your Vercel app URL in production
ALLOWED_ORIGIN=http://localhost:5173

# Secret key the frontend sends in the X-API-Key header
# Can be any random string — generate one with: openssl rand -hex 32
API_KEY=your-secret-api-key

# Max requests per minute per IP (default: 10)
RATE_LIMIT=10

# Port — injected automatically by Render, only set this for local dev
# PORT=8080

# -----------------------------------------------------------------------------
# Optional — ignore extra repos at runtime without redeploying
# Comma-separated list of repo names to exclude from embedding
# -----------------------------------------------------------------------------
# IGNORED_REPOS=my-private-repo,another-repo
