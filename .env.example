GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

GROQ_MODEL=llama-3.1-8b-instant // Example Gemini model - replace with your desired model
GEMINI_MODEL=gemini-2.5 // Example Gemini model - replace with your desired model

GITHUB_USERNAME=your_github_username_here
GITHUB_TOKEN=your_github_token_here

PORT=8080
ALLOWED_ORIGIN=http://localhost:3000 // Replace with your frontend URL in production

QDRANT_URL=your_qdrant_url_here
QDRANT_COLLECTION=your_qdrant_collection_name_here
QDRANT_API_KEY=your_qdrant_api_key_here


MONGODB_URI=your_mongodb_uri_here
MONGODB_DB=your_mongodb_db_name_here

API_KEY=your_api_key_here
RATE_LIMIT=10 // Max number of requests per minute - adjust as needed



